# Google Gemini API Key
GEMINI_API_KEY="your_gemini_api_key_here"

# Vertex AI Configuration (Optional: use in production Google Cloud instead of GEMINI_API_KEY)
# If GOOGLE_CLOUD_PROJECT is set, the SDK automatically switches to Vertex AI using IAM ADC credentials.
GOOGLE_CLOUD_PROJECT=""
GOOGLE_CLOUD_LOCATION="us-central1"

# Firebase Service Account Credentials JSON String
# Paste your entire Firebase service account JSON string here (contains project ID, private keys, etc.)
# Example: FIREBASE_SERVICE_ACCOUNT_JSON='{"type": "service_account", "project_id": "...", ...}'
FIREBASE_SERVICE_ACCOUNT_JSON=""

# Backend API Host URL (for frontend Next.js server actions)
NEXT_PUBLIC_API_URL="http://127.0.0.1:8000"

# Gemini AI Model Name Configuration (e.g. gemini-2.5-flash)
GEMINI_MODEL_NAME="gemini-2.5-flash"
